# Team Mu RAG chat API (chatbot/rag-engine)
# Copy to .env in repo root or chatbot/ and fill in values.

GROQ_API_KEY=your_groq_api_key_here

# Retrieval defaults (optional)
DEFAULT_TOP_K=4
# Chroma L2 distance: refuse if best (min) distance is greater than this
MAX_DISTANCE=1.2

# LLM re-ranking of a wider candidate pool. Set false to disable.
ENABLE_RERANK=true

# Agentic multi-hop retrieval (Phase 6). Set false to force single-shot retrieve.
ENABLE_MULTI_HOP=true
MAX_RETRIEVAL_ROUNDS=3

# Comma-separated origins for browser clients (Vite default)
CORS_ORIGINS=http://localhost:5173

# Answer cache (Phase 7 API layer)
ENABLE_CACHE=true
CACHE_TTL_SECONDS=900
CACHE_MAX_ENTRIES=200

# Rate limiting (per X-User-Id or client IP)
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_SECONDS=60

# Optional Redis for shared cache + rate limits (multi-instance deploy)
# REDIS_URL=redis://localhost:6379/0
