# Team Mu RAG chat API (chatbot/rag-engine)
# Copy to .env in repo root or chatbot/ and fill in values.

GROQ_API_KEY=your_groq_api_key_here

# Retrieval defaults (optional)
DEFAULT_TOP_K=4
# Chroma L2 distance: refuse if best (min) distance is greater than this
MAX_DISTANCE=1.2

# Comma-separated origins for browser clients (Vite default)
CORS_ORIGINS=http://localhost:5173
